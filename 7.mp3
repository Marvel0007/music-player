		@media only screen and (max-width:1270px) and (min-width:1151px) {
			.image-thumb {
				/* height: 175px; */
			}
		}


		/* @media only screen and (max-width:1150px) {
			.song-card {
				width: calc(20.5% - 13px);
			}

			.image-thumb {
				height: 160px;
			}
		} */

		@media only screen and (max-width:1325px) {

			.song-card {
				width: calc(25% - 9px);
			}

		}

		@media only screen and (max-width: 1023px) {
			.image-thumb {
				height: 160px;
			}

			.song-card {
				/* width: calc(25.3% - 11px); */
			}
		}

		@media only screen and (max-width:900px) and (min-width: 769px) {
			.image-thumb {
				/* height: 180px; */
			}
		}

		@media only screen and (max-width:900px) {
			.song-card {
				width: calc(33.4% - 9px)
			}

		}

		@media only screen and (max-width:768px) {
			.mainContent {
				flex-direction: column;
			}

			.main-content,
			.sidebar {
				width: 100%;
				margin: 0;
			}

			.sidebar-content {
				gap: 0;
			}


			.song-list {
				gap: 12px;
			}

			.song-list {
				padding: 12px;
			}

			.song-card {
				width: calc(33.6% - 10px)
			}
		}


		@media only screen and (max-width:620px) {
			.song-card {
				width: calc(33.74% - 10.5px)
			}
		}



		@media only screen and (max-width:576px) {
			.top-nav {
				flex-direction: column;
				gap: 8px;
				padding: 8px 10px 15px 10px;
			}

			.song-card {
				width: calc(34% - 10.5px)
			}

			.song-list {
				gap: 10px;
			}

			.song-list {
				padding: 10px;
			}

			.form-wrapper {
				width: 85%;
				/* 75% of screen */
				margin: 0 auto;
				float: none;
				/* height: 36px; */
			}

			.form-wrapper input {
				font-size: 15px;
			}

			.form-wrapper button {
				width: 60px;
			}

			.image-thumb {
				height: 155px;

			}
		}

		@media screen and (max-width: 480px) {
			.song-card {
				width: calc(48.5% - 3px);
			}

			.song-list {
				padding: 15px 1px 15px 8px;
				gap: 10px;
			}

			.nw {
				font-size: 13px;
			}
		}

		@media screen and (max-width: 368px) {
			.song-card {
				width: calc(48.4% - 4px);
			}
		}

		@media only screen and (max-width:425px) {
			.wlist li {
				width: 100%;
			}
		}

		@media only screen and (max-width:400px) {
			.form-wrapper {
				width: 92%;
			}
		}

		@media screen and (max-width: 350px) {
			.image-thumb {
				height: 152px;
			}
		}

		@media only screen and (max-width:320px) {

			.pgn a,
			.pgn span {
				padding: 7px 12px;
			}

			body {
				font-size: 13.5px;
				min-width: 200px;
			}

			.navbar {
				/* width: 100%; */
				font-size: 13px;
			}

			.ad {
				width: 100%;
			}

			.form-wrapper input {
				/* width: 70%; */
			}

			.vd {
				width: 250px;
				height: 160px
			}

			.search-bar {
				width: 99%;
			}

			.form-wrapper {
				/* width: 93%; */
			}

			.navbar a {
				width: 50%;
			}

			.icon {
				display: none
			}

			.heading {
				font-size: 15px;
			}

			tr.tr td {
				width: 100%;
				float: left
			}

			.td {
				width: 100%;
				max-width: 100%
			}

			.imgs {
				width: 100%;
				height: auto;
			}

			.expend+.smalldesc {
				max-height: 240px;
			}


		}

		@media (max-width: 280px) {
			#fixedban {
				display: none;
			}
		}

		@media only screen and (min-width:577px) {
			.form-wrapper {
				width: 55%;
			}
		}

		@media only screen and (min-width:768px) {
			header {
				text-align: left;
				background: #232526;
			}

			.navbar {
				width: 100%;
				font-size: 15px;
			}

			.navbar a {
				width: 16.666%;
			}

			.ad {
				width: 100%;
			}

			.vd {
				width: 520px;
			}

			.form-wrapper {
				width: 47%;
			}

			.form-wrapper input {
				/* width: 67%; */
			}

			.form-wrapper button {
				/* height: 26px; */
				/* top: 0px */
			}

			.search-bar {
				width: 99.8%;
			}

			.list li {
				display: inline-table;
				width: 47%;
			}

			.tab {
				width: 30%
			}

			.imgs {
				display: table;
				margin: 20px 15px 0 10px;
				float: left;
			}

			table {
				display: block;
				min-height: 207px;
			}

			.cd {
				text-align: left
			}

			.mpan {
				padding: 0px;
				background: #fff;
				margin: 0;
			}

			.heading {
				font-size: 17px;
			}

			.xxxl {
				font-size: 26px;
			}

			.expend+.smalldesc {
				max-height: 220px;
			}
		}

		@media only screen and (min-width:1025px) {
			header {
				max-width: 1260px;
				width: 86%;
			}

			main {
				max-width: 1260px;
				width: 86%
			}

			.navbar {
				display: flex;
				/* max-width: 1049px; */
				/* width: 81%; */
				font-size: 14px
			}

			.navbar a {
				width: 35%;
			}

			.vd {
				width: 480px;
			}

			.ad {
				width: 1260px;
				width: 100%;
			}

			.search-bar {
				width: 96%;
				padding-top: 0px;
				height: 42px;
			}

			.form-wrapper {
				width: 40%;
			}

			.form-wrapper input {
				/* width: 67%; */
				/* margin-top: 3px; */
			}

			.form-wrapper button {
				/* margin-top: 3px; */
			}

			footer {
				max-width: 1260px;
				width: 86%
			}

			.list li {
				display: inline-block;
				width: 47%;
			}

			.movie A:link,
			.movie A:visited,
			.movie A:hover,
			.movie A:active {
				text-decoration: none;
				color: #006600;
			}

			.movie {
				display: inline;
				margin-left: 20px;
				font-size: 14px;
			}

			.tab {
				width: 20%
			}

			.wlist li {
				padding: 6px 0 6px 7px;
			}

			.heading {
				font-size: 17px;
			}

			.expend+.smalldesc {
				max-height: 167px;
			}
		}

		.adslot_1 {
			width: 100%;
			height: 100px;
		}

		.popup-container {
			display: none;
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background-color: rgba(0, 0, 0, 0.7);
			z-index: 999;
			justify-content: center;
			align-items: center;
			text-align: center;
		}

		.popup-content {
			background-color: #fff;
			padding: 20px;
			border-radius: 10px;
			position: relative;
		}

		.popup-close {
			position: absolute;
			top: 10px;
			right: 10px;
			cursor: pointer;
			font-size: 50px;
		}

		.browsecats {
			font-family: Helvetica Neue, Helvetica, Arial, sans-serif;
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 20px;
			margin-top: 15px;
			padding: 25px;
		}

		.browsecats a.category-item {
			background-color: white;
			border-radius: 10px;
			display: flex;
			flex-direction: column;
			align-items: center;
			box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
			padding: 20px 15px;
			box-sizing: border-box;
			min-height: 140px;
			justify-content: space-between;
		}

		.browsecats a.category-item:hover {
			border: 1px solid #DC2626;
			box-shadow: 0 4px 15px rgba(211, 11, 0, 0.2);
		}

		.browsecats svg {
			width: 46px;
			fill: #DC2626;
		}

		.browsecats .category-item span {
			color: #333333;
			font-size: 15px;
			font-weight: 700;
			text-align: center;
		}

		.browsecats .post-count {
			border-radius: 12px;
			background-color: #0056AD1A;
			font-size: 12px;
			padding: 2px 8px;
		}

		@media (max-width: 1133px) {
			.browsecats {
				grid-template-columns: repeat(3, 1fr);
				font-size: 13px;
			}
		}

		@media (max-width: 534px) {
			.browsecats {
				grid-template-columns: repeat(2, 1fr);
				font-size: 12px;
			}
		}

		@media (max-width: 372px) {
			.browsecats {
				font-size: 10px;
			}
		}
	</style>
</head>

