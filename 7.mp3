	<style>
		body {
			background: #fff;
			color: #000;
		}

		body * {
			margin: 0;
			padding: 0;
			font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
			font-size: 14px;
			line-height: 1.5;
			border: 0;
			margin-left: auto;
			margin-right: auto;
			letter-spacing: -.3px;
			font-size: 14px;
		}

		a img,
		:link img,
		:visited img {
			border: none;
		}

		a {
			text-decoration: none;
			color: #000;
		}

		a:hover {
			text-decoration: none;
			color: #ff0000;
		}

		html,
		body,
		div,
		span,
		h1,
		h2,
		h3,
		h4,
		h5,
		h6,
		p,
		a,
		em,
		img,
		strong,
		b,
		u,
		i,
		center,
		ol,
		ul,
		li,
		form,
		label,
		article,
		aside,
		details,
		embed,
		figure,
		figcaption,
		footer,
		header,
		hgroup,
		menu,
		.navbar,
		section,
		summary,
		time,
		mark,
		audio,
		video,
		td {
			margin: 0;
			padding: 0;
			border: 0;
			font-size: 100%;
			vertical-align: baseline;
		}

		i {
			font: inherit;
		}

		b {
			font-weight: bold;
		}

		textarea {
			font-size: small;
		}

		main {
			width: 100%;
			margin-left: auto;
			margin-right: auto;
			margin-top: 20px
		}

		.mainContent {
			display: flex;

		}

		.main-content {
			width: 75%;
			height: auto;
			margin-right: 15px;
		}

		.ts-head {
			display: flex;
			align-items: center;
			color: #fff;
			padding: 6px 6px 6px 10px;
			background-color: #232526;
			border-bottom-width: 2px;
			border-bottom-style: solid;
			border-image: linear-gradient(to right, #8e2de2, #ff4e9b) 1;
		}

		.ts-head .tsHeading {
			text-align: left;
			padding-left: 5px;
			font-size: 17px;
			font-weight: 400;
		}

		.ts-head svg {
			color: red;
			width: 24px;
			height: 24px;
			vertical-align: middle;
			margin: 0;
		}

		.sidebar {
			width: 25%;
		}

		.ts-content {
			height: auto;
			padding: 8px;
			background: #f7f7f7;
			border: 1px solid #f7f7f7;
		}

		.ts-content li:last-child a {
			margin-bottom: 0;
		}

		.ts-ul {
			list-style-type: none;
		}

		.ts-song {
			display: flex;
			align-items: center;
			background-color: #fff;
			padding: 8px;
			line-height: 1.4;
			margin-bottom: 8px;
			border-radius: 3px;
		}

		.song-thumb img {
			width: 60px;
			height: 60px;
			object-fit: cover;
			border-radius: 6px;
		}

		.song-content {
			margin-left: 10px;
			min-width: 0;
		}

		.song-content .title-box {
			margin: 0;
			font-size: 14px;
			white-space: nowrap;
			overflow: hidden;
			font-weight: 300;
			text-overflow: ellipsis;
			width: 100%;
			line-height: 1.2;
		}

		.album-name {
			font-size: 12px;
			color: #777;
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
			width: 100%;
			line-height: 1.2;
			margin: 2px 0 0;
		}

		.sidebar-content {
			position: sticky;
			top: 20px;
			align-self: flex-start;
			display: flex;
			flex-direction: column;
			gap: 20px;
		}





		.song-card {
			position: relative;
			overflow: hidden;
		}

		/* PLAY BUTTON WRAPPER */
		.playBtn {
			position: absolute;
			top: 45%;
			left: 50%;
			transform: translate(-50%, -50%) scale(0.6);
			width: 65px;
			height: 65px;
			border-radius: 50%;
			border: 2px solid #e4e4e4;
			display: flex;
			align-items: center;
			justify-content: center;
			opacity: 0;
			transition: all 0.35s ease;
			z-index: 5;
			background: rgba(0, 0, 0, 0.6);
		}

		.playBtn svg {
			width: 28px;
			height: 28px;
			transition: transform 0.3s ease;
		}

		.song-card:hover .playBtn {
			opacity: 1;
			transform: translate(-50%, -50%) scale(0.8);
		}

		.song-card:hover .playBtn svg {
			transform: scale(1);
		}

		.song-card a::after {
			content: "";
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 170px;
			background: rgba(0, 0, 0, 0.35);
			opacity: 0;
			transition: opacity 0.35s ease;
			pointer-events: none;
			z-index: 2;
		}

		.song-card a::after {
			background: rgba(0, 0, 0, 0.35);
		}

		/* Show overlay on hover */
		.song-card:hover a::after {
			opacity: 1;
		}






















